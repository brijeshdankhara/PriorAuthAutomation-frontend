# Used by `vite build` (what Vercel runs). Not used for local dev, which
# has its own values in .env.local (gitignored). None of these are secrets
# -- a Cognito user pool/client ID and an API path are meant to be visible
# in client-side JS; the actual security boundary is Cognito's own SRP auth
# and the API's own authorization checks, not obscurity of these values.
VITE_COGNITO_USER_POOL_ID=us-east-1_KgPmRBFcK
VITE_COGNITO_CLIENT_ID=ocmfgok9dgut40lcnnnn6h5rh
VITE_API_BASE=/auto-pa-test/api
